<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowAnimationStyle">@style/AppActivityAnimation</item>
        <item name="android:windowIsTranslucent">false</item>
        <item name="android:colorBackground">@color/color_window_background</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
        <item name="android:windowDisablePreview">true</item>
        <item name="android:colorBackgroundCacheHint">@null</item>
        <item name="android:spinnerStyle">@style/AppSpinnerStyle</item>
        <item name="android:spinnerItemStyle">@style/DropDownItemStyle</item>
        <item name="android:textAppearanceListItem">@style/AppTextAppearance.Primary</item>
        <item name="android:textAppearanceListItemSecondary">@style/AppTextAppearance.Secondary</item>
        <item name="preferenceCategoryStyle">@style/AppPreferenceCategory</item>
        <item name="android:listPreferredItemPaddingLeft">@dimen/preference_item_child_padding</item>
        <item name="android:listPreferredItemPaddingStart">@dimen/preference_item_child_padding</item>
        <item name="colorAccent">@color/highlight_normal_light</item>
        <item name="colorControlActivated">@color/highlight_normal_light</item>
        <item name="dialogTheme">@style/AppDialogStyle</item>
        <item name="alertDialogTheme">@style/AppDialogStyle</item>
        <item name="preferenceTheme">@style/AppPreferenceTheme</item>
        <item name="actionOverflowMenuStyle">@style/OverflowMenuStyle</item>
    </style>

    <style name="AppPreferenceTheme" parent="@style/PreferenceThemeOverlay.v14.Material">
        <item name="preferenceFragmentCompatStyle">@style/AppPreferenceFragmentCompatStyle</item>
        <item name="preferenceStyle">@style/AppPreferenceStyle</item>
        <item name="switchPreferenceCompatStyle">@style/AppPreferenceStyle</item>
        <item name="checkBoxPreferenceStyle">@style/AppPreferenceStyle</item>
        <item name="seekBarPreferenceStyle">@style/AppSeekBarPreference</item>
    </style>

    <style name="AppPreferenceStyle" parent="@style/Preference.Material">
        <item name="android:textColorPrimary">#FFFFFF</item>
        <item name="android:textColorSecondary">@color/preference_category_text_color</item>
    </style>

    <style name="AppSeekBarPreference" parent="@style/Preference.SeekBarPreference.Material">
        <item name="android:textColorPrimary">#FFFFFF</item>
        <item name="android:textColorSecondary">@color/preference_category_text_color</item>
    </style>

    <style name="AppTextAppearance.Secondary" parent="TextAppearance.AppCompat.Small">
        <item name="android:textColor">@color/preference_category_text_color</item>
        <item name="android:textSize">@dimen/secondary_text_size</item>
    </style>

    <style name="AppPreferenceCategory" parent="PreferenceCategoryTitleTextStyle">
        <item name="android:textColor">@color/preference_category_text_color</item>
        <item name="android:textSize">@dimen/preference_category_text_size</item>
    </style>

    <style name="AppSpinnerStyle" parent="@style/Widget.AppCompat.Spinner.DropDown">
        <item name="overlapAnchor">false</item>
    </style>
    <style name="DropDownItemStyle" parent="@style/Widget.AppCompat.TextView.SpinnerItem">
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">8dp</item>
    </style>
    <style name="AppActivityAnimation" parent="@android:style/Animation">
        <item name="android:activityOpenEnterAnimation">@anim/activity_open_enter</item>
        <item name="android:activityOpenExitAnimation">@anim/activity_open_exit</item>
        <item name="android:activityCloseEnterAnimation">@anim/activity_close_enter</item>
        <item name="android:activityCloseExitAnimation">@anim/activity_close_exit</item>
    </style>
    <style name="AppDialogStyle" parent="ThemeOverlay.AppCompat.Dialog">
        <item name="android:windowBackground">@drawable/popup_background</item>
        <item name="android:windowMinWidthMajor">65%</item>
        <item name="android:windowMinWidthMinor">80%</item>
    </style>
    <style name="AppPreferenceFragmentCompatStyle" parent="@style/PreferenceFragment.Material">
        <item name="android:layout">@layout/prefs_fragment_base</item>
    </style>
    <style name="OverflowMenuStyle" parent="@style/Widget.AppCompat.PopupMenu.Overflow">
        <item name="android:overlapAnchor">false</item>
        <item name="android:popupBackground">@drawable/popmenu_background</item>
    </style>
    <style name="Invisible" parent="@android:style/Theme.Translucent">
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:windowFrame">@null</item>
        <item name="android:windowCloseOnTouchOutside">true</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
    </style>
    <style name="ApplyInvisible">
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:windowFrame">@null</item>
        <item name="android:windowCloseOnTouchOutside">true</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:colorBackgroundCacheHint">@null</item>
        <item name="android:windowIsTranslucent">true</item>
    </style>
    <style name="AppTextAppearance">
        <item name="android:textSize">@dimen/secondary_text_size</item>
        <item name="android:textColor">@color/preference_category_text_color</item>
    </style>
    <style name="AppTextAppearance.Primary" parent="TextAppearance.AppCompat.Subhead">
        <item name="android:textSize">@dimen/normal_text_size</item>
        <item name="android:textStyle">normal</item>
    </style>
    <style name="Widget.InputField.Category">
        <item name="android:paddingBottom">9dp</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:layout_height">50dp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:paddingStart">@dimen/preference_item_child_padding</item>
        <item name="android:textSize">@dimen/preference_category_text_size</item>
        <item name="android:textColor">@color/preference_category_text_color</item>
    </style>
</resources>